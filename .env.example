# Frontend (Vite) — prefixed with VITE_; never put secrets here
VITE_API_URL=/api
VITE_UPLOADS_URL=/uploads
VITE_APP_NAME=Procraft

# Backend PostgreSQL connectivity (preferred for tooling + containers)
DATABASE_URL=

POSTGRES_DB=procraft
POSTGRES_USER=
POSTGRES_PASSWORD=

# Jwt signing + metadata (supply via environment or dotnet user secrets in development)
JWT_SECRET=
JWT_ISSUER=procraft.uz
JWT_AUDIENCE=procraft.uz
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# Cookie identifiers (mirror appsettings Cookies section before production rollout)
JWT_ACCESS_COOKIE_NAME=__Host-procraft_access
JWT_REFRESH_COOKIE_NAME=__Host-procraft_refresh
CSRF_COOKIE_NAME=procraft_csrf
CSRF_HEADER_NAME=X-CSRF-TOKEN

# Writable volume for uploads (mapped into appsettings Uploads:RootPath externally)
UPLOADS_ROOT=/var/uploads
