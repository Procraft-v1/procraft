# Frontend (Vite) - prefixed with VITE_; never put secrets here
VITE_API_URL=/api
VITE_UPLOADS_URL=/uploads
VITE_APP_NAME=Procraft


# ASP.NET Core runtime
ASPNETCORE_ENVIRONMENT=Development

# Backend PostgreSQL connectivity
POSTGRES_DB=procraft
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT signing and metadata
JWT_SECRET=dev-only-change-this-secret-key-at-least-32-characters
JWT_ISSUER=https://api.procraft.uz
JWT_AUDIENCE=https://api.procraft.uz
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# Browser CORS origins for production/container deployments.
# Keep /api and /uploads proxied through the public frontend domain in nginx/Cloudflare.
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5173,https://procraft.uz,https://www.procraft.uz

# Cookie identifiers
JWT_ACCESS_COOKIE_NAME=__Host-procraft_access
JWT_REFRESH_COOKIE_NAME=__Host-procraft_refresh
CSRF_COOKIE_NAME=procraft_csrf
CSRF_COOKIE_DOMAIN=.procraft.uz
JWT_COOKIE_SAMESITE=None
JWT_COOKIE_SECURE=true

# Writable volume for uploaded files
UPLOADS_ROOT=uploads
