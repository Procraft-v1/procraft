# Frontend (Vite) - prefixed with VITE_; never put secrets here
VITE_API_URL=https://api.procraft.uz/api
VITE_UPLOADS_URL=https://api.procraft.uz/uploads
VITE_APP_NAME=Procraft

# Static admin panel credentials. Keep real values only in deployment secrets.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345
ADMIN_SESSION_SECRET=admin_session_secret_admin12345_22_08_05_xx


# ASP.NET Core runtime
ASPNETCORE_ENVIRONMENT=Development

# Backend PostgreSQL connectivity
POSTGRES_DB=procraft
POSTGRES_USER=postgres
POSTGRES_PASSWORD=procraft_db_password_2026_08_05_15_xx

# JWT signing and metadata
JWT_SECRET=procraft_super_secret_jwt_key_2026_08_05_very_secure_xx
JWT_ISSUER=https://api.procraft.uz
JWT_AUDIENCE=https://api.procraft.uz
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# Browser CORS origins for production/container deployments.
# Keep /api and /uploads proxied through the public frontend domain in nginx/Cloudflare.
CORS_ALLOWED_ORIGINS=https://procraft.uz,https://www.procraft.uz,https://dashboard.procraft.uz,https://admin.procraft.uz

# Cookie identifiers
JWT_ACCESS_COOKIE_NAME=__Host-procraft_access
JWT_REFRESH_COOKIE_NAME=__Host-procraft_refresh
CSRF_COOKIE_NAME=procraft_csrf
CSRF_COOKIE_DOMAIN=.procraft.uz
JWT_COOKIE_SAMESITE=None
JWT_COOKIE_SECURE=true

# Writable volume for uploaded files
UPLOADS_ROOT=uploads

# SMTP for email verification codes. Use deployment secrets for real values.
Smtp__Host=smtp.resend.com
Smtp__Port=587
Smtp__Username=resend
Smtp__Password=re_xxxxxxxxxxxxxxxxx
Smtp__FromAddress=noreply@procraft.uz
Smtp__FromName=Procraft
Smtp__EnableSsl=true

# Eskiz.uz SMS (phone verification). Register at https://eskiz.uz to get credentials.
Eskiz__Email=your@email.com
Eskiz__Password=your_eskiz_password
Eskiz__Sender=4546

# Telegram bot verification (free alternative to email/SMS)
# Create bot via @BotFather, set webhook to https://api.procraft.uz/api/telegram/webhook
Telegram__BotToken=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
Telegram__BotUsername=procraft_bot
Telegram__WebhookUrl=https://api.procraft.uz/api/telegram/webhook
