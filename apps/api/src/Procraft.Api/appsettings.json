{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "",
    "Audience": "",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7,
    "Secret": ""
  },
  "Cookies": {
    "AccessCookieName": "__Host-procraft_access",
    "RefreshCookieName": "__Host-procraft_refresh",
    "CsrfCookieName": "procraft_csrf",
    "SameSite": "Lax",
    "Secure": true
  },
  "Uploads": {
    "RootPath": "uploads",
    "PublicBasePath": "/uploads",
    "MaxAvatarSizeMb": 5
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Cors": {
    "DevelopmentOrigins": [
      "http://localhost:5173",
      "http://localhost:5174",
      "http://localhost:5175"
    ]
  },
  "AllowedHosts": "*"
}
