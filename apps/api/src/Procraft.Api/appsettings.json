{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "",
    "Audience": "",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7,
    "Secret": ""
  },
  "Cookies": {
    "AccessCookieName": "__Host-procraft_access",
    "RefreshCookieName": "__Host-procraft_refresh",
    "CsrfCookieName": "procraft_csrf",
    "CsrfCookieDomain": ".procraft.uz",
    "SameSite": "Lax",
    "Secure": true
  },
  "Uploads": {
    "RootPath": "uploads",
    "PublicBasePath": "/uploads",
    "MaxAvatarSizeMb": 5,
    "MaxCertificateSizeMb": 10
  },
  "Cors": {
    "AllowedOrigins": "https://procraft.uz,https://www.procraft.uz,https://dashboard.procraft.uz,https://admin.procraft.uz"
  },
  "Admin": {
    "Username": "",
    "Password": "",
    "SessionSecret": ""
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromAddress": "noreply@procraft.uz"
  },
  "Telegram": {
    "BotToken": "",
    "ChatId": ""
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
