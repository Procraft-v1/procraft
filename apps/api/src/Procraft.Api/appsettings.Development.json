{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=procraft;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Secret": "dev-only-change-this-secret-key-at-least-32-characters",
    "Issuer": "procraft.local",
    "Audience": "procraft.local",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Cookies": {
    "AccessCookieName": "__Host-procraft_access",
    "RefreshCookieName": "__Host-procraft_refresh",
    "CsrfCookieName": "procraft_csrf",
    "SameSite": "Lax",
    "Secure": false
  },
  "Uploads": {
    "RootPath": "uploads",
    "PublicBasePath": "/uploads",
    "MaxAvatarSizeMb": 5
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug"
    }
  }
}
